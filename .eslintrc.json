{
  "root": true,
  "env": {
    "node": true,
    "es2021": true
  },
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "overrides": [
    {
      "files": [
        "tests/**/*.ts"
      ],
      "env": {
        "node": true
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "playwright-report/",
    "test-results/"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "off"
  }
}
