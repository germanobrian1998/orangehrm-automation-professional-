{
  "name": "orangehrm-automation-professional-",
  "version": "1.0.0",
  "description": "Professional QA Automation Framework for OrangeHRM using Playwright and TypeScript.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke",
    "test:integration": "playwright test tests/integration",
    "test:regression": "playwright test tests/regression",
    "test:performance": "playwright test tests/performance",
    "test:api": "playwright test tests/api",
    "test:ui": "playwright test --ui",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "type-check": "tsc --noEmit",
    "build": "tsc --project tsconfig.json"
  },
  "author": "germanobrian1998",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
